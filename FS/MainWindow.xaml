<Window x:Class="BetterFileSys.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BetterFileSys"
        xmlns:viewmodels="clr-namespace:BetterFileSys.ViewModels"
        xmlns:models="clr-namespace:BetterFileSys.Models"
        Title="VaultRecon - Semantic Search &amp; Explorer" Height="780" Width="1200" 
        WindowStartupLocation="CenterScreen" Background="#0C0D11">
    
    <Window.Resources>
        <!-- Header Filter Button Style -->
        <Style x:Key="SortHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource HoverGrayBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Windows 11-style Context Menu Style -->
        <Style x:Key="ModernContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="#161822" />
            <Setter Property="BorderBrush" Value="#2E3245" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ItemsPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Context Menu Item Style -->
        <Style x:Key="ModernMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="border" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" Content="{TemplateBinding Icon}" VerticalAlignment="Center"/>
                                <ContentPresenter Grid.Column="1" Content="{TemplateBinding Header}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{TemplateBinding InputGestureText}" Foreground="{StaticResource TextSecondaryBrush}" Margin="20,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2B2F47" />
                                <Setter Property="Foreground" Value="{StaticResource CyanAccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Windows 11 Context Menu Resource -->
        <ContextMenu x:Key="Windows11Menu" Style="{StaticResource ModernContextMenuStyle}">
            <!-- Action Bar (Cut, Copy, Rename, Share, Delete) -->
            <MenuItem StaysOpenOnClick="True">
                <MenuItem.Header>
                    <Grid Width="270" Margin="-20,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Cut -->
                        <Button Grid.Column="0" Command="{Binding Path=PlacementTarget.Tag.CopyPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" ToolTip="Cut" Style="{StaticResource SmallToolbarButton}">
                            <StackPanel>
                                <TextBlock Text="✂️" FontSize="14" HorizontalAlignment="Center"/>
                                <TextBlock Text="Cut" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>
                        <!-- Copy -->
                        <Button Grid.Column="1" Command="{Binding Path=PlacementTarget.Tag.CopyPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" ToolTip="Copy" Style="{StaticResource SmallToolbarButton}">
                            <StackPanel>
                                <TextBlock Text="📄" FontSize="14" HorizontalAlignment="Center"/>
                                <TextBlock Text="Copy" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>
                        <!-- Rename -->
                        <Button Grid.Column="2" Command="{Binding Path=PlacementTarget.Tag.ShowPropertiesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" ToolTip="Rename" Style="{StaticResource SmallToolbarButton}">
                            <StackPanel>
                                <TextBlock Text="✏️" FontSize="14" HorizontalAlignment="Center"/>
                                <TextBlock Text="Rename" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>
                        <!-- Share -->
                        <Button Grid.Column="3" Command="{Binding Path=PlacementTarget.Tag.CopyPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" ToolTip="Share" Style="{StaticResource SmallToolbarButton}">
                            <StackPanel>
                                <TextBlock Text="↪️" FontSize="14" HorizontalAlignment="Center"/>
                                <TextBlock Text="Share" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>
                        <!-- Delete -->
                        <Button Grid.Column="4" Command="{Binding Path=PlacementTarget.Tag.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" ToolTip="Delete" Style="{StaticResource SmallToolbarButton}">
                            <StackPanel>
                                <TextBlock Text="🗑️" FontSize="14" HorizontalAlignment="Center"/>
                                <TextBlock Text="Delete" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </MenuItem.Header>
            </MenuItem>
            
            <Separator Background="#2E3245" Margin="0,4"/>
            
            <!-- Standard Items -->
            <MenuItem Header="Open" Command="{Binding Path=PlacementTarget.Tag.OpenFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" InputGestureText="Enter" Style="{StaticResource ModernMenuItemStyle}">
                <MenuItem.Icon>
                    <TextBlock Text="🚀" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>
            
            <MenuItem Header="Run as administrator" Command="{Binding Path=PlacementTarget.Tag.RunAsAdminCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Style="{StaticResource ModernMenuItemStyle}">
                <MenuItem.Icon>
                    <TextBlock Text="🛡️" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>
            
            <MenuItem Header="Open folder location" Command="{Binding Path=PlacementTarget.Tag.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Style="{StaticResource ModernMenuItemStyle}">
                <MenuItem.Icon>
                    <TextBlock Text="📁" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem Header="Copy as path" Command="{Binding Path=PlacementTarget.Tag.CopyPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" InputGestureText="Ctrl+Shift+C" Style="{StaticResource ModernMenuItemStyle}">
                <MenuItem.Icon>
                    <TextBlock Text="🔗" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>
            
            <MenuItem Header="Properties" Command="{Binding Path=PlacementTarget.Tag.ShowPropertiesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" InputGestureText="Alt+Enter" Style="{StaticResource ModernMenuItemStyle}">
                <MenuItem.Icon>
                    <TextBlock Text="ℹ️" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>
            
            <Separator Background="#2E3245" Margin="0,4"/>
            
            <MenuItem Header="Edit in Notepad" Command="{Binding Path=PlacementTarget.Tag.EditInNotepadCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Style="{StaticResource ModernMenuItemStyle}">
                <MenuItem.Icon>
                    <TextBlock Text="📝" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <!-- Tab Navigation Buttons Style -->
        <Style x:Key="TabHeaderButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1F3A3F58"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search Result ListBoxItem Style -->
        <Style x:Key="SearchResultItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Setter Property="ContextMenu" Value="{StaticResource Windows11Menu}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" 
                                Background="#161822" 
                                BorderBrush="#2E3245" 
                                BorderThickness="1" 
                                CornerRadius="8" 
                                Margin="0,0,0,8" 
                                Padding="15,12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1C1E2B" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource CyanAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#251A3D" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource PurpleAccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Explorer Column ListBoxItem Style -->
        <Style x:Key="ExplorerItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Setter Property="ContextMenu" Value="{StaticResource Windows11Menu}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" 
                                Background="Transparent" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2A1E4A" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2A1E4A" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource PurpleAccentBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="0,0,0,0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Button Style -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource HoverGrayBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small Toolbar Button Style -->
        <Style x:Key="SmallToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource HoverGrayBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2E3245"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top Dashboard Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Main Content Area -->
            <RowDefinition Height="*"/>
            <!-- Bottom Status Footer -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Header & Navigation -->
        <Border Grid.Row="0" Background="#161822" BorderBrush="#2E3245" BorderThickness="0,0,0,1" Padding="20,15,20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                    <TextBlock Text="Vault" FontSize="20" FontWeight="Bold" Foreground="{StaticResource CyanAccentBrush}"/>
                    <TextBlock Text="Recon" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <Border Background="#2E3245" CornerRadius="4" Margin="10,2,0,2" Padding="6,2">
                        <TextBlock Text="v1.0" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                </StackPanel>

                <!-- View Selection Tabs -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                    <!-- Tab 0: Semantic Search -->
                    <Button Content="Semantic Search" Command="{Binding SelectSearchTabCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabHeaderButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab}" Value="0">
                                        <Setter Property="Foreground" Value="{StaticResource CyanAccentBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource CyanAccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <!-- Tab 1: File Explorer -->
                    <Button Content="File Explorer" Command="{Binding SelectExplorerTabCommand}" Margin="20,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabHeaderButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab}" Value="1">
                                        <Setter Property="Foreground" Value="{StaticResource PurpleAccentBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource PurpleAccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Status Summary -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                    <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#CCCCCC"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsIndexing}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource CyanAccentBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsIndexing}" Value="False">
                                        <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding IndexStatusMessage}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Sidebar Navigation Pane -->
                <ColumnDefinition Width="220"/>
                <!-- Interactive Tab content -->
                <ColumnDefinition Width="*"/>
                <!-- Global File Preview pane -->
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR NAVIGATION PANE (COLUMN 0) -->
            <Border Grid.Column="0" Background="#111216" BorderBrush="#2E3245" BorderThickness="0,0,1,0" VerticalAlignment="Stretch">
                <Grid Margin="15,15,15,5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Style="{StaticResource ModernScrollViewer}">
                        <StackPanel>
                            <!-- Drives Section -->
                            <TextBlock Text="Drives" FontSize="11" FontWeight="Bold" Foreground="#4F567A" Margin="0,0,0,10"/>
                            
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="💾" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1">
                                    <Grid>
                                        <TextBlock Text="C: Main Disk" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="759 GB" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <ProgressBar Value="72" Height="4" Foreground="{StaticResource CyanAccentBrush}" Background="#2E3245" BorderThickness="0" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Network Section -->
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="Network" FontSize="11" FontWeight="Bold" Foreground="#4F567A"/>
                                <TextBlock Text="..." FontSize="12" Foreground="#4F567A" HorizontalAlignment="Right" Cursor="Hand"/>
                            </Grid>
                            
                            <!-- User Profile Folder Section (sarve) -->
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="sarve" FontSize="11" FontWeight="Bold" Foreground="#4F567A"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="..." FontSize="12" Foreground="#4F567A" Margin="0,0,8,0" Cursor="Hand"/>
                                    <TextBlock Text="+" FontSize="12" Foreground="#4F567A" Cursor="Hand"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Navigation Items styled exactly like OneCommander -->
                            <StackPanel Margin="0,0,0,20">
                                <!-- This PC -->
                                <Button Command="{Binding SelectExplorerTabCommand}" Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🖥️" Margin="0,0,10,0" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Text="This PC" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Button>
                                <!-- Desktop -->
                                <Button Command="{Binding NavigateDesktopCommand}" Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🖥️" Margin="0,0,10,0" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Text="Desktop" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Button>
                                <!-- Documents -->
                                <Button Command="{Binding NavigateDocumentsCommand}" Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📁" Margin="0,0,10,0" FontSize="13" Foreground="#EAB308" VerticalAlignment="Center"/>
                                        <TextBlock Text="Documents" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Button>
                                <!-- Pictures -->
                                <Button Command="{Binding NavigatePicturesCommand}" Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🏞️" Margin="0,0,10,0" FontSize="13" Foreground="#06B6D4" VerticalAlignment="Center"/>
                                        <TextBlock Text="Pictures" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Button>
                                <!-- Videos -->
                                <Button Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎬" Margin="0,0,10,0" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Text="Videos" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Button>
                                <!-- Music -->
                                <Button Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎵" Margin="0,0,10,0" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Text="Music" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Button>
                                <!-- Downloads -->
                                <Button Command="{Binding NavigateDownloadsCommand}" Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📥" Margin="0,0,10,0" FontSize="13" Foreground="#3B82F6" VerticalAlignment="Center"/>
                                        <TextBlock Text="Downloads" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Button>
                                <!-- Programs -->
                                <Button Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚙️" Margin="0,0,10,0" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Text="Programs" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Button>
                                <!-- Recent Items -->
                                <Button Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⏱️" Margin="0,0,10,0" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Text="Recent Items" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Button>
                                <!-- Recycle Bin -->
                                <Button Style="{StaticResource SidebarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🗑️" Margin="0,0,10,0" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Text="Recycle Bin" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            
                            <!-- New Group Button -->
                            <Button Content="New group" Foreground="{StaticResource TextSecondaryBrush}" Padding="10,6" Margin="0,0,0,20" HorizontalAlignment="Stretch">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="#2E3245"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource HoverGrayBrush}"/>
                                                            <Setter Property="BorderBrush" Value="#5E6382"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            
                            <!-- History Section -->
                            <TextBlock Text="History" FontSize="11" FontWeight="Bold" Foreground="#4F567A" Margin="0,0,0,10"/>
                            <Button Command="{Binding NavigatePicturesCommand}" Style="{StaticResource SidebarButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏞️" Margin="0,0,10,0" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Text="Pictures" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                    
                    <!-- Bottom Mini Toolbar -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,5,0,0">
                        <Button Content="ℹ️" Style="{StaticResource SmallToolbarButton}" FontSize="12" Margin="0,0,12,0"/>
                        <Button Content="⚙️" Style="{StaticResource SmallToolbarButton}" FontSize="12" Margin="0,0,12,0"/>
                        <Button Content="🔍" Style="{StaticResource SmallToolbarButton}" FontSize="12" Margin="0,0,12,0"/>
                        <Button Content="🔄" Style="{StaticResource SmallToolbarButton}" FontSize="12" Margin="0,0,12,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- TAB PAGES CONTAINER (COLUMN 1) -->
            <Grid Grid.Column="1" Margin="20">
                
                <!-- TAB 0: SEMANTIC SEARCH PANEL -->
                <Grid x:Name="SearchPanel">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="1">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    
                    <Grid.RowDefinitions>
                        <!-- Search Box Row -->
                        <RowDefinition Height="Auto"/>
                        <!-- Header Filter Bar Row -->
                        <RowDefinition Height="Auto"/>
                        <!-- Results List Row -->
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search Inputs -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox Grid.Column="0" Height="42" 
                                 Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Tag="Search files by meaning or filename...">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding PerformSearchCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        
                        <Button Grid.Column="1" Content="Search" Width="100" Height="42" Margin="10,0,0,0" 
                                Command="{Binding PerformSearchCommand}" Style="{StaticResource AccentButton}"/>
                        
                        <Button Grid.Column="2" Content="Clear" Width="80" Height="42" Margin="10,0,0,0" 
                                Command="{Binding ClearSearchCommand}" Style="{StaticResource ModernButton}"/>
                    </Grid>

                    <!-- Sort Filter Header Bar -->
                    <Border Grid.Row="1" Background="#161822" BorderBrush="#2E3245" BorderThickness="1" CornerRadius="6" Padding="15,8" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Name Sort Trigger -->
                            <Button Grid.Column="0" Command="{Binding SortResultsCommand}" CommandParameter="Name" Style="{StaticResource SortHeaderButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Name" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="  ▲" FontSize="9" VerticalAlignment="Center" Foreground="{StaticResource CyanAccentBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.CurrentSortColumn, RelativeSource={RelativeSource AncestorType=Window}}" Value="Name"/>
                                                            <Condition Binding="{Binding DataContext.IsSortAscending, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="  ▼" FontSize="9" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.CurrentSortColumn, RelativeSource={RelativeSource AncestorType=Window}}" Value="Name"/>
                                                            <Condition Binding="{Binding DataContext.IsSortAscending, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>

                            <!-- Date modified Sort Trigger -->
                            <Button Grid.Column="1" Command="{Binding SortResultsCommand}" CommandParameter="Date modified" Style="{StaticResource SortHeaderButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Date modified" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="  ▲" FontSize="9" VerticalAlignment="Center" Foreground="{StaticResource CyanAccentBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.CurrentSortColumn, RelativeSource={RelativeSource AncestorType=Window}}" Value="Date modified"/>
                                                            <Condition Binding="{Binding DataContext.IsSortAscending, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="  ▼" FontSize="9" VerticalAlignment="Center" Foreground="{StaticResource CyanAccentBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.CurrentSortColumn, RelativeSource={RelativeSource AncestorType=Window}}" Value="Date modified"/>
                                                            <Condition Binding="{Binding DataContext.IsSortAscending, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>

                            <!-- Type Sort Trigger -->
                            <Button Grid.Column="2" Command="{Binding SortResultsCommand}" CommandParameter="Type" Style="{StaticResource SortHeaderButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Type" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="  ▲" FontSize="9" VerticalAlignment="Center" Foreground="{StaticResource CyanAccentBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.CurrentSortColumn, RelativeSource={RelativeSource AncestorType=Window}}" Value="Type"/>
                                                            <Condition Binding="{Binding DataContext.IsSortAscending, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="  ▼" FontSize="9" VerticalAlignment="Center" Foreground="{StaticResource CyanAccentBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.CurrentSortColumn, RelativeSource={RelativeSource AncestorType=Window}}" Value="Type"/>
                                                            <Condition Binding="{Binding DataContext.IsSortAscending, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>

                            <!-- Size Sort Trigger -->
                            <Button Grid.Column="3" Command="{Binding SortResultsCommand}" CommandParameter="Size" Style="{StaticResource SortHeaderButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Size" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="  ▲" FontSize="9" VerticalAlignment="Center" Foreground="{StaticResource CyanAccentBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.CurrentSortColumn, RelativeSource={RelativeSource AncestorType=Window}}" Value="Size"/>
                                                            <Condition Binding="{Binding DataContext.IsSortAscending, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="  ▼" FontSize="9" VerticalAlignment="Center" Foreground="{StaticResource CyanAccentBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.CurrentSortColumn, RelativeSource={RelativeSource AncestorType=Window}}" Value="Size"/>
                                                            <Condition Binding="{Binding DataContext.IsSortAscending, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>

                            <!-- Score Sort Trigger -->
                            <Button Grid.Column="4" Command="{Binding SortResultsCommand}" CommandParameter="Score" Style="{StaticResource SortHeaderButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Score" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="  ▲" FontSize="9" VerticalAlignment="Center" Foreground="{StaticResource CyanAccentBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.CurrentSortColumn, RelativeSource={RelativeSource AncestorType=Window}}" Value="Score"/>
                                                            <Condition Binding="{Binding DataContext.IsSortAscending, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="  ▼" FontSize="9" VerticalAlignment="Center" Foreground="{StaticResource CyanAccentBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.CurrentSortColumn, RelativeSource={RelativeSource AncestorType=Window}}" Value="Score"/>
                                                            <Condition Binding="{Binding DataContext.IsSortAscending, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Search Results Cards -->
                    <ListBox Grid.Row="2" ItemsSource="{Binding SearchResults}" 
                             SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0" 
                             ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemContainerStyle="{StaticResource SearchResultItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SearchResult}">
                                <Grid>
                                    <Grid.InputBindings>
                                        <MouseBinding Gesture="LeftDoubleClick" Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    </Grid.InputBindings>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 1: File Name + Extension Badge -->
                                    <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal">
                                        <TextBlock Text="📄" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding FileName}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Match Type Badge -->
                                    <Border Grid.Column="1" Grid.Row="0" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2E3245" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SearchType}" Value="Semantic">
                                                        <Setter Property="Background" Value="#002D33" />
                                                        <Setter Property="BorderBrush" Value="#00F2FE" />
                                                        <Setter Property="BorderThickness" Value="1" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SearchType}" Value="Hybrid">
                                                        <Setter Property="Background" Value="#250F3A" />
                                                        <Setter Property="BorderBrush" Value="#7F00FF" />
                                                        <Setter Property="BorderThickness" Value="1" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="10" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Keyword" />
                                                    <Setter Property="Foreground" Value="#9499B0" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SearchType}" Value="Semantic">
                                                            <Setter Property="Text" Value="Semantic" />
                                                            <Setter Property="Foreground" Value="#00F2FE" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SearchType}" Value="Hybrid">
                                                            <Setter Property="Text" Value="Hybrid" />
                                                            <Setter Property="Foreground" Value="#D8B4FE" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- Row 2: File Path -->
                                    <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" 
                                               Text="{Binding FilePath}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" 
                                               Margin="22,4,0,4" TextTrimming="CharacterEllipsis"/>

                                    <!-- Row 3: Size & Date Details -->
                                    <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" Orientation="Horizontal" Margin="22,2,0,0">
                                        <TextBlock Text="Size: " FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding FormattedSize}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,15,0"/>
                                        
                                        <TextBlock Text="Modified: " FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding Modified, StringFormat={}{0:yyyy-MM-dd HH:mm}}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,15,0"/>

                                        <TextBlock Text="Score: " FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding RelevanceScore, StringFormat={}{0:F2}}" FontSize="11" Foreground="{StaticResource CyanAccentBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- TAB 1: MILLER COLUMNS FILE EXPLORER PANEL -->
                <Grid x:Name="ExplorerPanel">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="1">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Grid.RowDefinitions>
                        <!-- Breadcrumbs -->
                        <RowDefinition Height="Auto"/>
                        <!-- Folder title & item count details -->
                        <RowDefinition Height="Auto"/>
                        <!-- Toolbar/Action bar -->
                        <RowDefinition Height="Auto"/>
                        <!-- Miller Columns ScrollViewer -->
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Breadcrumbs -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="This PC" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="  \  " FontSize="11" Foreground="#4F567A"/>
                        <TextBlock Text="C:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="  \  " FontSize="11" Foreground="#4F567A"/>
                        <TextBlock Text="{Binding ActiveFolderPath}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <!-- Row 1: Folder title & details -->
                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ActiveFolderName}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding ActiveFolderItemCount, StringFormat='  ({0})'}" FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Bottom" Margin="5,0,0,2"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ActiveFolderTotalSize}" FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,5,2"/>
                    </Grid>

                    <!-- Row 2: OneCommander-style toolbar/action bar -->
                    <Border Grid.Row="2" Background="#161822" BorderBrush="#2E3245" BorderThickness="1" CornerRadius="6" Padding="12,6" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Left: Navigation Arrows -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Button Content="←" Style="{StaticResource SmallToolbarButton}" FontSize="12" Margin="0,0,12,0"/>
                                <Button Content="→" Style="{StaticResource SmallToolbarButton}" FontSize="12" Margin="0,0,12,0"/>
                                <Button Content="↑" Style="{StaticResource SmallToolbarButton}" FontSize="12" Margin="0,0,12,0"/>
                                <Button Content="⌂" Style="{StaticResource SmallToolbarButton}" FontSize="12"/>
                            </StackPanel>

                            <!-- Middle: View Styles -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="≡ List" Style="{StaticResource SmallToolbarButton}" FontSize="11" Margin="0,0,15,0"/>
                                <Button Content="⊞ Grid" Style="{StaticResource SmallToolbarButton}" FontSize="11" Margin="0,0,15,0"/>
                                <Button Content="📊 Columns" Style="{StaticResource SmallToolbarButton}" Foreground="{StaticResource CyanAccentBrush}" FontSize="11" FontWeight="Bold"/>
                            </StackPanel>

                            <!-- Right: Sorting & Refresh -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Content="⇅ Sort" Style="{StaticResource SmallToolbarButton}" FontSize="11" Margin="0,0,12,0"/>
                                <Button Content="🔄 Refresh" Style="{StaticResource SmallToolbarButton}" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Row 3: Miller Columns ScrollViewer -->
                    <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Style="{StaticResource ModernScrollViewer}">
                        <!-- Horizontal list of Columns -->
                        <ItemsControl ItemsSource="{Binding Columns}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewmodels:DirectoryColumnViewModel}">
                                    <Border Width="360" BorderBrush="#2E3245" BorderThickness="0,0,1,0" Background="#13141C" VerticalAlignment="Stretch">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <!-- Column Header Title -->
                                                <RowDefinition Height="Auto"/>
                                                <!-- Column ListBox -->
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- Header Title -->
                                            <Border Grid.Row="0" Background="#1A1C29" Padding="12,10" BorderBrush="#2E3245" BorderThickness="0,0,0,1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📁" Margin="0,0,6,0" FontSize="12" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Column File List -->
                                            <ListBox Grid.Row="1" ItemsSource="{Binding Items}" 
                                                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                                     Background="Transparent" BorderThickness="0"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                     ItemContainerStyle="{StaticResource ExplorerItemStyle}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type models:FileItem}">
                                                        <Grid Margin="0,2">
                                                            <Grid.InputBindings>
                                                                <MouseBinding Gesture="LeftDoubleClick" Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                            </Grid.InputBindings>
                                                            <Grid.ColumnDefinitions>
                                                                <!-- Icon + Name -->
                                                                <ColumnDefinition Width="*"/>
                                                                <!-- Extension Tag -->
                                                                <ColumnDefinition Width="45"/>
                                                                <!-- Age Badge -->
                                                                <ColumnDefinition Width="40"/>
                                                                <!-- Modified -->
                                                                <ColumnDefinition Width="105"/>
                                                                <!-- Size -->
                                                                <ColumnDefinition Width="60"/>
                                                                <!-- Chevron -->
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Icon + Name -->
                                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <TextBlock FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="📄" />
                                                                            <Setter Property="Foreground" Value="{StaticResource CyanAccentBrush}" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                                                    <Setter Property="Text" Value="📁" />
                                                                                    <Setter Property="Foreground" Value="#EAB308" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding Name}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                            </StackPanel>

                                                            <!-- Extension -->
                                                            <TextBlock Grid.Column="1" Text="{Binding ExtensionTag}" FontSize="10.5" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"/>

                                                            <!-- Age Pill -->
                                                            <Border Grid.Column="2" CornerRadius="4" Padding="4,2" HorizontalAlignment="Center" VerticalAlignment="Center" Background="{Binding RelativeAgeColor}">
                                                                <TextBlock Text="{Binding RelativeAge}" FontSize="9.5" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>

                                                            <!-- Date Modified -->
                                                            <TextBlock Grid.Column="3" Text="{Binding Modified, StringFormat={}{0:yyyy-MM-dd HH:mm}}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="6,0,0,0"/>

                                                            <!-- Size -->
                                                            <TextBlock Grid.Column="4" Text="{Binding FormattedSize}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"/>

                                                            <!-- Chevron -->
                                                            <TextBlock Grid.Column="5" Text="›" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="2,0,2,0" VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- GLOBAL FILE PREVIEW PANE (COLUMN 2) -->
            <Border Grid.Column="2" Background="#161822" BorderBrush="#2E3245" BorderThickness="1,0,0,0" VerticalAlignment="Stretch">
                <Grid>
                    <!-- Null State Panel (Visible when SelectedFileItem is null) -->
                    <Grid x:Name="NullStatePreview" Margin="30">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFileItem}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="🔍" FontSize="48" Margin="0,0,0,15" HorizontalAlignment="Center" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Text="No Selection" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,5,0"/>
                            <TextBlock Text="Select a search result or file in the columns to preview contents." 
                                       FontSize="12" HorizontalAlignment="Center" TextAlignment="Center" 
                                       Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <!-- Active File Details & Preview Panel (Visible when SelectedFileItem is NOT null) -->
                    <Grid x:Name="ActivePreview" Margin="20">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFileItem}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        
                        <Grid.RowDefinitions>
                            <!-- Metadata Header -->
                            <RowDefinition Height="Auto"/>
                            <!-- Action Buttons -->
                            <RowDefinition Height="Auto"/>
                            <!-- Divider -->
                            <RowDefinition Height="Auto"/>
                            <!-- Text Content Preview -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header Metadata (OneCommander Visual Layout) -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,15">
                            <!-- Massive Visual Preview Card -->
                            <Border Background="#1C1E2B" BorderBrush="#2E3245" BorderThickness="1" CornerRadius="12" Height="140" Margin="0,0,0,15" SnapsToDevicePixels="True">
                                <Grid>
                                    <!-- Giant Icon representation based on Type -->
                                    <TextBlock FontSize="64" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="📄" />
                                                <Setter Property="Foreground" Value="{StaticResource CyanAccentBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedFileItem.FileType}" Value="Folder">
                                                        <Setter Property="Text" Value="📁" />
                                                        <Setter Property="Foreground" Value="#EAB308" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedFileItem.ExtensionTag}" Value="png">
                                                        <Setter Property="Text" Value="🖼️" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedFileItem.ExtensionTag}" Value="jpg">
                                                        <Setter Property="Text" Value="🖼️" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedFileItem.ExtensionTag}" Value="jpeg">
                                                        <Setter Property="Text" Value="🖼️" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedFileItem.ExtensionTag}" Value="gif">
                                                        <Setter Property="Text" Value="🖼️" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedFileItem.ExtensionTag}" Value="pdf">
                                                        <Setter Property="Text" Value="📕" />
                                                        <Setter Property="Foreground" Value="#EF4444" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedFileItem.ExtensionTag}" Value="docx">
                                                        <Setter Property="Text" Value="📘" />
                                                        <Setter Property="Foreground" Value="#3B82F6" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedFileItem.ExtensionTag}" Value="doc">
                                                        <Setter Property="Text" Value="📘" />
                                                        <Setter Property="Foreground" Value="#3B82F6" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedFileItem.ExtensionTag}" Value="xlsx">
                                                        <Setter Property="Text" Value="📗" />
                                                        <Setter Property="Foreground" Value="#10B981" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <!-- Filename Title -->
                            <TextBlock Text="{Binding SelectedFileItem.FileName}" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            
                            <!-- Properties list -->
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="85"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Name" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedFileItem.FileName}" FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            </Grid>
                            
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="85"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Type" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedFileItem.ExtensionTag}" FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Grid>
                            
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="85"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Modified" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedFileItem.Modified, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Grid>
                            
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="85"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Age" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedFileItem.RelativeAge}" FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Grid>

                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="85"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Size" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedFileItem.FormattedSize}" FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Grid>
                            
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="85"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Full Path" FontSize="11.5" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedFileItem.FilePath}" FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>

                        <!-- Action Buttons -->
                        <UniformGrid Grid.Row="1" Rows="1" Columns="3" Margin="0,0,0,15">
                            <Button Content="Open File" Command="{Binding OpenFileCommand}" Style="{StaticResource ModernButton}" Margin="0,0,4,0" Padding="4,8"/>
                            <Button Content="Open Folder" Command="{Binding OpenFolderCommand}" Style="{StaticResource ModernButton}" Margin="2,0,2,0" Padding="4,8"/>
                            <Button Content="Copy Path" Command="{Binding CopyPathCommand}" Style="{StaticResource ModernButton}" Margin="4,0,0,0" Padding="4,8"/>
                        </UniformGrid>

                        <!-- Divider -->
                        <Border Grid.Row="2" BorderBrush="#2E3245" BorderThickness="0,0,0,1" Margin="0,0,0,15">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelectedFileText}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <!-- Text Preview Content -->
                        <Grid Grid.Row="3">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelectedFileText}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="CONTENT PREVIEW (First 100 lines)" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                            
                            <!-- Read-only Text Box preview -->
                            <TextBox Grid.Row="1" Text="{Binding SelectedFileContentPreview}" 
                                     IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                                     Background="#0C0D11" Foreground="#A9B2C3" 
                                     BorderBrush="#2E3245" BorderThickness="1"
                                     FontFamily="Consolas, Courier New" FontSize="11" 
                                     Padding="10" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFilePreviewLoading}" Value="True">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            
                            <!-- Loading Text Overlay -->
                            <TextBlock Grid.Row="1" Text="Loading content preview..." FontSize="12" Foreground="{StaticResource CyanAccentBrush}" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFilePreviewLoading}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Footer -->
        <Border Grid.Row="2" Background="#161822" BorderBrush="#2E3245" BorderThickness="0,1,0,0" Padding="15,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Grid.Column="1" Text="Phase 5: Miller Columns &amp; Theme Complete" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
