<Window x:Class="BetterFileSys.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Better FileSys - Semantic File Search" Height="700" Width="1000" WindowStartupLocation="CenterScreen">
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Background="#FFFFFF">
            <StackPanel Margin="15" VerticalAlignment="Top">
                <TextBlock Text="Better FileSys - Semantic Search" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                
                <!-- Search Input -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox Grid.Column="0" Height="40" Margin="0,0,0,0" Padding="12,8" FontSize="14" 
                             Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"
                             Foreground="#333333" Background="#FFFFFF" BorderBrush="#CCCCCC" BorderThickness="1"/>
                    
                    <Button Grid.Column="1" Content="Search" Width="80" Height="40" Margin="8,0,0,0" 
                            Command="{Binding PerformSearchCommand}" Background="#0078D4" Foreground="White" FontWeight="Bold"/>
                    
                    <Button Grid.Column="2" Content="Clear" Width="80" Height="40" Margin="8,0,0,0" 
                            Command="{Binding ClearSearchCommand}" Background="#E81B23" Foreground="White" FontWeight="Bold"/>
                </Grid>
                
                <!-- Status Bar -->
                <TextBlock Text="{Binding StatusMessage}" Margin="0,10,0,0" FontSize="12" Foreground="#666666"/>
            </StackPanel>
        </Grid>

        <!-- Results Grid -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding SearchResults}" AutoGenerateColumns="False" 
                  Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0" 
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0"
                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                  Margin="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*" MinWidth="200"/>
                <DataGridTextColumn Header="Size" Binding="{Binding FormattedSize}" Width="100"/>
                <DataGridTextColumn Header="Type" Binding="{Binding FileType}" Width="80"/>
                <DataGridTextColumn Header="Modified" Binding="{Binding Modified}" Width="160"/>
                <DataGridTextColumn Header="Path" Binding="{Binding FilePath}" Width="300" MinWidth="200"/>
                <DataGridTextColumn Header="Score" Binding="{Binding RelevanceScore}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <TextBlock Grid.Row="2" Text="Phase 1: Keyword Search (Everything SDK)" Margin="15,8" 
                   FontSize="11" Foreground="#999999" Background="#FFFFFF"/>
    </Grid>
</Window>
